{
  "name": "@cafedebug/api-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "orval --config orval.config.ts",
    "contract:check": "orval --config orval.config.ts",
